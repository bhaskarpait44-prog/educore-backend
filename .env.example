# Application Settings
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=educore_db
DB_USER=postgres
DB_PASSWORD=
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Security & Authentication
JWT_SECRET=your_very_secure_random_secret_string
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173

# Email (SMTP) Configuration for Password Resets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_NAME="EduCore Support"
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Push Notifications (Optional/Future use)
FCM_SERVER_KEY=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
